# ====== 原有：模型 / 数据源密钥 ======
SILICONFLOW_API_KEY=sk-xxxxxxxxxxx
DASHSCOPE_API_KEY=xxxxxxxxxx
OPENAI_API_KEY=xxx

ARXIV_API_URL=http://export.arxiv.org/api/query

# ====== 二次开发新增：Redis ======
# 本地直跑用 localhost；docker-compose 中请改为服务名 redis
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=
REDIS_DB_BROKER=0
REDIS_DB_BACKEND=1
REDIS_DB_APP=2

# ====== 二次开发新增：MySQL ======
# docker-compose 中请改为服务名 mysql
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=paper_agent
MYSQL_PASSWORD=paper_agent
MYSQL_DB=paper_agent

# ====== 二次开发新增：业务参数 ======
# 人工审核等待超时 (秒)
HUMAN_INPUT_TIMEOUT=600
# LLM/Embedding 缓存
LLM_CACHE_ENABLED=true
LLM_CACHE_TTL=86400
# Redis key 统一前缀
PA_KEY_PREFIX=pa
# 允许跨域的前端域 (逗号分隔)
CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:3000

# docker-compose 下建议直接使用服务名 (取消下面注释)
# REDIS_HOST=redis
# MYSQL_HOST=mysql
